      "exclusive": false,
      "tags": ["oath_stele", "silver_oath"]
    },
    {
      "id": "hint_ch1_lamplight_or_lumina",
      "chapterId": "chapter_1",
      "text": "废墟深处有微弱灯火，像补给点，也像某种残留星辉。",
