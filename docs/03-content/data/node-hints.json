  "baseHints": [
    {
      "id": "hint_ch1_outer_ruins_shadows",
      "chapterId": "chapter_1",
      "text": "要塞外缘的灰白废墟里，有几处影子在缓慢游荡。",
      "exclusive": false,
      "tags": ["outer_corruption", "undead"]
    },
    {
      "id": "hint_ch1_broken_wall_carrion",
      "chapterId": "chapter_1",
      "text": "破碎城墙外传来腐肉拖行和低哑啃咬声。",
      "exclusive": false,
      "tags": ["outer_corruption", "undead"]
    },
    {
      "id": "hint_ch1_circling_vultures",
      "chapterId": "chapter_1",
      "text": "空中有黑影盘旋，地面也留下被啃食过的痕迹。",
      "exclusive": false,
      "tags": ["outer_corruption", "vulture"]
    },
    {
      "id": "hint_ch1_rift_beast_growl",
      "chapterId": "chapter_1",
      "text": "地下裂隙附近传来压低的兽吼，紫黑色雾气贴着地面流动。",
      "exclusive": false,
      "tags": ["void_rift", "beast"]
    },
    {
      "id": "hint_ch1_rift_claw_marks",
      "chapterId": "chapter_1",
      "text": "裂隙边缘布满爪痕和拖拽痕，像有什么东西刚刚经过。",
      "exclusive": false,
      "tags": ["void_rift", "beast"]
    },
    {
      "id": "hint_ch1_plague_mist_steps",
      "chapterId": "chapter_1",
      "text": "废墟低处涌出腥甜的疫雾，里面偶尔传来湿重脚步声。",
      "exclusive": false,
      "tags": ["poison", "plague"]
    },
    {
      "id": "hint_ch1_corrupted_tunnel_glow",
      "chapterId": "chapter_1",
      "text": "被污染的坑道里亮着零星紫光，空气里混着腐败和星辉残味。",
      "exclusive": false,
      "tags": ["void_rift", "lumina"]
    },
    {
      "id": "hint_ch1_training_ground_lines",
      "chapterId": "chapter_1",
      "text": "前方似乎是昔日的新人骑士训练场，地面还残留着步法刻线。",
      "exclusive": false,
      "tags": ["training", "silver_oath"]
    },
    {
      "id": "hint_ch1_training_flags_armor",
      "chapterId": "chapter_1",
      "text": "银白色训练旗倒在废墟边缘，远处传来整齐的甲胄声。",
      "exclusive": false,
      "tags": ["training", "silver_oath_remnant"]
    },
    {
      "id": "hint_ch1_wall_crossbow_sounds",
      "chapterId": "chapter_1",
      "text": "城墙方向传来弩机拉弦声，残破垛口后有银光闪动。",
      "exclusive": false,
      "tags": ["wall", "aim", "silver_oath_remnant"]
    },
    {
      "id": "hint_ch1_old_formation",
      "chapterId": "chapter_1",
      "text": "断墙后的旧阵地仍像在执行命令，盾牌和弩线交错成残阵。",
      "exclusive": false,
      "tags": ["shield", "aim", "silver_oath_remnant"]
    },
    {
      "id": "hint_ch1_armory_rust",
      "chapterId": "chapter_1",
      "text": "前方似乎是旧军械库的残区，铁锈和封存药剂的气味混在一起。",
      "exclusive": false,
      "tags": ["armory", "supply"]
    },
    {
      "id": "hint_ch1_armory_shield_rack",
      "chapterId": "chapter_1",
      "text": "半塌的库门后露出封存箱和旧盾架，金属拖地声从深处传来。",
      "exclusive": false,
      "tags": ["armory", "shield"]
    },
    {
      "id": "hint_ch1_bell_tower_echo",
      "chapterId": "chapter_1",
      "text": "远处钟楼残影在雾中摇晃，低沉回声沿着石道传来。",
