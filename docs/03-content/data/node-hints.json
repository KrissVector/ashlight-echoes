    {
      "id": "hint_ch1_small_campfire",
      "chapterId": "chapter_1",
      "text": "前方似乎是个小型营地，隐约可看见篝火和炊烟。",
      "exclusive": false,
      "tags": ["camp", "shop", "blood_banner_remnant"]
    },
    {
      "id": "hint_ch1_old_waystation_tracks",
      "chapterId": "chapter_1",
      "text": "前方似乎是个旧驿站，地上有着车辙的痕迹。",
      "exclusive": false,
      "tags": ["waystation", "shop", "outer_corruption"]
    },
    {
      "id": "hint_ch1_wasteland_footsteps",
      "chapterId": "chapter_1",
      "text": "荒原边缘传来急促脚步声，空中有黑影跟着盘旋。",
      "exclusive": false,
      "tags": ["wasteland", "chase", "vulture"]
    },
    {
      "id": "hint_ch1_chase_traces",
      "chapterId": "chapter_1",
      "text": "断枝和碎石间残留着追逐痕迹，前方像刚爆发过一场混乱。",
      "exclusive": false,
      "tags": ["chase", "outer_corruption"]
    },
    {
      "id": "hint_ch1_silver_light_path",
      "chapterId": "chapter_1",
      "text": "要塞深处的银色残光凝成一条路，像在把人引向旧日誓约的遗留之处。",
      "exclusive": false,
      "tags": ["silver_oath", "oath_stele"]
    },
    {
      "id": "hint_ch1_ordered_guard_traces",
      "chapterId": "chapter_1",
      "text": "前方的守卫痕迹变得异常整齐，像有人仍在维持骑士团最后的阵列。",
      "exclusive": false,
      "tags": ["silver_oath_remnant", "shield"]
    },
    {
      "id": "hint_ch1_training_stakes",
      "chapterId": "chapter_1",
      "text": "破损木桩沿训练线排开，像刚有人复盘过旧式守势。",
      "exclusive": false,
      "tags": ["training", "defense"]
    },
    {
      "id": "hint_ch1_silver_lamp_device",
      "chapterId": "chapter_1",
      "text": "银誓遗留的灯器还在发光，周围没有明显脚印。",
      "exclusive": false,
      "tags": ["lumina", "infirmary", "shop"]
    },
    {
      "id": "hint_ch1_story_last_stand",
      "chapterId": "chapter_1",
      "text": "血旗残党已经追上来，灼夜的护身符在混乱中发出灼热回响。",
      "exclusive": true,
      "tags": ["fixed_story", "chapter_1_step_6"]
    },
    {
      "id": "hint_ch1_story_breakout",
      "chapterId": "chapter_1",
      "text": "后方追兵逼近，前方残墙只留下一条勉强突围的空隙。",
      "exclusive": true,
      "tags": ["fixed_story", "chapter_1_step_6"]
    },
    {
      "id": "hint_ch1_boss_reinhardt",
      "chapterId": "chapter_1",
      "text": "要塞最深处传来沉重的盾击声，银白残光在断裂王座前凝成最后的守门人。",
      "exclusive": true,
      "tags": ["boss", "silver_oath"]
    }
